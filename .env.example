# ===================================================================
# Paula Pango — Environment variables template
# ===================================================================
# Copy this file to `.env.local` (gitignored) and fill in real values
# before running `npm run dev` or deploying. Never commit `.env.local`.
# ===================================================================

# ---------- Site / Base URL ----------
NEXT_PUBLIC_SITE_URL=https://www.paulapango.com

# ---------- Firebase (create a NEW project named "paulapango") ----------
# Project Settings → General → Your apps → SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=paulapango.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=paulapango
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=paulapango.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (Service Account JSON → "Generate new private key")
FIREBASE_PROJECT_ID=paulapango
FIREBASE_CLIENT_EMAIL=
# Paste the private key on a single line; literal "\n" sequences will be
# converted to real newlines at runtime.
FIREBASE_PRIVATE_KEY=

# Firestore root path for product/article documents
NEXT_PUBLIC_CLIENT_ID=paulapango

# ---------- Stripe ----------
# Use TEST keys for development, LIVE keys for production
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- Email (Zoho SMTP via nodemailer) ----------
ZOHO_SMTP_SERVER=smtp.zoho.com
NEXT_PUBLIC_EMAIL_USERNAME=info@paulapango.com
MAIL_PASS=

# Optional: Postmark for order confirmation emails
POSTMARK_SERVER_TOKEN=

# ---------- Google Analytics / Tag Manager ----------
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID_LT=
NEXT_PUBLIC_GTM_ID=

# ---------- Google Ads (conversion tracking, optional) ----------
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL=
